# HistoryBites backend env vars

# Deployment environment label. Used for log context.
ENVIRONMENT=development

# Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Postgres connection string. Required — the app will fail to start without it.
# In production, Railway injects this automatically via the Postgres addon.
# For local dev against the Railway DB, use DATABASE_PUBLIC_URL from the Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Wikipedia API User-Agent. Required per Wikipedia's etiquette policy.
# Format: AppName/Version (contact-email-or-url).
WIKIPEDIA_USER_AGENT=HistoryBites/0.1 (juragear@gmail.com)
