# HistoryBites backend env vars

# Deployment environment label. Used for log context.
ENVIRONMENT=development

# Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Postgres connection string. Required — the app will fail to start without it.
# In production, Railway injects this automatically via the Postgres addon.
# For local dev against the Railway DB, use DATABASE_PUBLIC_URL from the Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Wikipedia API User-Agent. Required per Wikipedia's etiquette policy.
# Format: AppName/Version (contact-email-or-url).
WIKIPEDIA_USER_AGENT=HistoryBites/0.1 (juragear@gmail.com)

# Model provider — "gemini" (production) or "ollama" (local dev). See D16.
MODEL_PROVIDER=gemini

# Gemini (required when MODEL_PROVIDER=gemini). Get the API key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Ollama (only used when MODEL_PROVIDER=ollama). Base URL of the local daemon
# and the installed model tag from `ollama list`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# Stored with every generated fact so we can invalidate the pool after prompt changes.
PROMPT_VERSION=v1

# Bearer token for /admin/* endpoints + the /admin/review page (Step 8).
# Required — the app refuses to boot if it's missing. Generate with e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(32))"` and set the
# same value on Railway and in your local .env.
ADMIN_TOKEN=

# Firebase Cloud Messaging (Step 9). Required — boots crash without it.
# Value is the ENTIRE service account JSON file contents as a single-line
# string. Generate from Firebase Console → Project Settings → Service
# accounts → Generate new private key. Compact to a single line first
# (python -c "import json,sys;print(json.dumps(json.load(open('sa.json'))))").
FIREBASE_SERVICE_ACCOUNT_JSON=

# FCM topic the daily push lands on (D17). Android + future iOS clients
# subscribe to this topic on first launch. No per-user tokens.
FCM_TOPIC=daily-fact

# Webhook for cron alerts (Step 10). Step 9 only declares the var so we don't
# revisit config in the next session — actual alerting wires up next step.
# Leave blank in development; set to a Slack/Discord/etc. webhook URL in prod.
ALERT_WEBHOOK_URL=

# Comma-separated list of allowed CORS origins. Use * for dev, explicit list
# for prod (e.g. https://your.domain,http://localhost:3000). Step 12 wires
# CORSMiddleware with allow_credentials=False so the wildcard actually works.
CORS_ORIGINS=*
